{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "*.rules",
      "*.indexes.json",
      "*.md",
      "node_modules"
    ],
    "rewrites": [
      {
        "source": "/portal/**",
        "destination": "/portal.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600" }]
      },
      {
        "source": "**/*.css",
        "headers": [{ "key": "Cache-Control", "value": "max-age=86400" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
