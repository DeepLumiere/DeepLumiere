rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserTeamDoc(orgId) {
      let teamId = "tm_" + orgId + "_" + request.auth.uid;
      return get(/databases/$(database)/documents/team/$(teamId));
    }
    
    function getUserRole(orgId) {
      let teamId = "tm_" + orgId + "_" + request.auth.uid;
      return exists(/databases/$(database)/documents/team/$(teamId)) ? get(/databases/$(database)/documents/team/$(teamId)).data.role : 'None';
    }
    
    function isAdminOrOwner(orgId) {
      let role = getUserRole(orgId);
      return role == 'Admin' || role == 'Owner';
    }
    
    function isInOrg(orgId) {
      let teamId = "tm_" + orgId + "_" + request.auth.uid;
      return exists(/databases/$(database)/documents/team/$(teamId)) && get(/databases/$(database)/documents/team/$(teamId)).data.orgId == orgId;
    }

    // Rules
    
    // Users profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }
    
    // Organizations
    match /organizations/{orgId} {
      allow read: if isAuthenticated() && isInOrg(orgId);
      allow write: if isAdminOrOwner(orgId) || (isAuthenticated() && !exists(/databases/$(database)/documents/organizations/$(orgId))); 
    }
    
    // Team Members
    match /team/{teamId} {
      allow read: if isAuthenticated() && (resource.data.email == request.auth.token.email || resource.data.uid == request.auth.uid || isInOrg(resource.data.orgId));
      allow write: if isAuthenticated() && (isAdminOrOwner(request.resource.data.orgId) || request.auth.uid == request.resource.data.uid);
    }
    
    // Clients
    match /clients/{clientId} {
      allow read: if isAuthenticated() && isInOrg(resource.data.orgId);
      allow write: if isAuthenticated() && isAdminOrOwner(request.resource.data.orgId);
    }
    
    // Subteams
    match /subteams/{subteamId} {
      allow read: if isAuthenticated() && isInOrg(resource.data.orgId);
      allow write: if isAuthenticated() && isAdminOrOwner(request.resource.data.orgId);
    }
    
    // Tickets
    match /tickets/{ticketId} {
      allow create: if (isAuthenticated() && isInOrg(request.resource.data.orgId)) || 
                       (request.resource.data.source == 'portal' && request.resource.data.clientToken != null && request.resource.data.clientToken != '' && exists(/databases/$(database)/documents/clients/$(request.resource.data.clientToken)) && get(/databases/$(database)/documents/clients/$(request.resource.data.clientToken)).data.orgId == request.resource.data.orgId);
      
      // All workspace members can read tasks, and portal clients can read theirs
      allow read: if (isAuthenticated() && isInOrg(resource.data.orgId)) || 
                     (resource.data.source == 'portal' && resource.data.clientToken != null && resource.data.clientToken != '' && exists(/databases/$(database)/documents/clients/$(resource.data.clientToken)));
      
      // Only admins or assignees can edit
      allow update: if isAuthenticated() && isInOrg(resource.data.orgId) && (
        isAdminOrOwner(resource.data.orgId) || 
        resource.data.assignee == "tm_" + resource.data.orgId + "_" + request.auth.uid || 
        resource.data.assignee == "" ||
        request.resource.data.status != resource.data.status // allow status updates by anyone in org
      );
      
      allow delete: if isAuthenticated() && isAdminOrOwner(resource.data.orgId);
    }
    
    // Projects
    match /projects/{projectId} {
      allow read: if isAuthenticated() && isInOrg(resource.data.orgId);
      allow write: if isAuthenticated() && isAdminOrOwner(request.resource.data.orgId);
    }
  }
}
